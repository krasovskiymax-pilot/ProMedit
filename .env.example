# NeonDB (PostgreSQL) — скопируйте в .env и подставьте свои значения
# Получите connection strings на https://neon.tech (Dashboard → Connection Details)

# Pooled connection (runtime, serverless) — endpoint с -pooler
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection (миграции Prisma)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
